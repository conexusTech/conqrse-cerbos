# Cerbos Local Development Configuration

# Log Level: debug, info, warn, error
CERBOS_LOG_LEVEL=info

# Server Configuration
CERBOS_HTTP_PORT=3592
CERBOS_GRPC_PORT=3593
CERBOS_METRICS_PORT=3591

# CORS Configuration (for local development)
CERBOS_CORS_ENABLED=true
CERBOS_CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080

# Storage Configuration
CERBOS_STORAGE_DRIVER=disk
CERBOS_STORAGE_WATCH=true

# Audit Logging
CERBOS_AUDIT_ENABLED=true
