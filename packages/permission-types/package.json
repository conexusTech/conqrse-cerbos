{
  "name": "@conqrse/permission-types",
  "version": "1.0.3",
  "description": "Enums and types for Conqrse permission integration with Cerbos",
  "type": "module",
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./index.ts"
    },
    "./enums": {
      "types": "./enums/index.ts",
      "default": "./enums/index.ts"
    },
    "./enums/*": {
      "types": "./enums/*.ts",
      "default": "./enums/*.ts"
    },
    "./types": {
      "types": "./types/index.ts",
      "default": "./types/index.ts"
    },
    "./types/*": {
      "types": "./types/*.ts",
      "default": "./types/*.ts"
    }
  },
  "files": [
    "README.md",
    "**/*.ts",
    "**/*.js",
    "**/*.d.ts"
  ],
  "keywords": [
    "conqrse",
    "cerbos",
    "permissions",
    "rbac",
    "enums",
    "types"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conqrse/conqrse-cerbos.git",
    "directory": "packages/permission-types"
  },
  "license": "UNLICENSED"
}
