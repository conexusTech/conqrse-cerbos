{
  "name": "@conqrse/permission-types",
  "version": "1.8.0",
  "description": "Enums and types for Conqrse permission integration with Cerbos",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./enums": {
      "types": "./dist/enums/index.d.ts",
      "require": "./dist/enums/index.js",
      "import": "./dist/enums/index.js",
      "default": "./dist/enums/index.js"
    },
    "./enums/*": {
      "types": "./dist/enums/*.d.ts",
      "require": "./dist/enums/*.js",
      "import": "./dist/enums/*.js",
      "default": "./dist/enums/*.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/types/index.js",
      "import": "./dist/types/index.js",
      "default": "./dist/types/index.js"
    },
    "./types/*": {
      "types": "./dist/types/*.d.ts",
      "require": "./dist/types/*.js",
      "import": "./dist/types/*.js",
      "default": "./dist/types/*.js"
    }
  },
  "scripts": {
    "build": "tsc"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "keywords": [
    "conqrse",
    "cerbos",
    "permissions",
    "rbac",
    "enums",
    "types"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conqrse/conqrse-cerbos.git",
    "directory": "packages/permission-types"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
