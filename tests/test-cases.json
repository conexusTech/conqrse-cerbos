{
  "testSuites": [
    {
      "name": "Allow Scenarios",
      "description": "Valid access patterns that should ALLOW",
      "tests": [
        {
          "id": "allow_1",
          "name": "Retailer Member Listing QR Campaigns",
          "description": "Retailer-level user viewing campaigns in their own retailer",
          "principal": {
            "id": "user-123",
            "roles": [
              "user"
            ],
            "attr": {
              "userLevel": "retailer",
              "userType": "member",
              "name": "john.doe",
              "products": [
                "qr"
              ],
              "agencyId": "agency-456",
              "retailerId": "retail-789"
            }
          },
          "resource": {
            "kind": "qr:campaigns",
            "id": "qr:campaigns",
            "attr": {
              "product": "qr",
              "retailerId": "retail-789",
              "agencyId": "agency-456"
            }
          },
          "expectedResult": "ALLOW",
          "actions": [
            "resource:list"
          ]
        },
        {
