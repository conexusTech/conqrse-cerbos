{
  "testSuites": [
    {
      "name": "Allow Scenarios",
      "description": "Valid access patterns that should ALLOW",
      "tests": [
        {
          "id": "allow_1",
          "name": "Retailer Member Listing QR Campaigns",
          "description": "Retailer-level user viewing campaigns in their own retailer",
          "principal": {
            "id": "user-123",
            "userLevel": "retailer",
            "userType": "member",
            "name": "john.doe",
            "products": [
              "qr"
            ],
            "agencyId": "agency-456",
            "retailerId": "retail-789",
            "isDelegating": false
          },
          "resource": {
            "name": "qr:campaigns",
            "product": "qr",
            "retailerId": "retail-789",
            "agencyId": "agency-456"
          },
          "action": "resource:list",
          "expectedResult": "ALLOW"
        },
        {
          "id": "allow_11",
          "name": "Agency Owner Viewing Agency Dashboard",
          "description": "Agency-level owner accessing their agency dashboard",
          "principal": {
            "id": "agency-user-010",
