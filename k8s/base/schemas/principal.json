{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Principal",
  "description": "User or service principal making the request",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique user identifier"
    },
    "userLevel": {
      "type": "string",
      "enum": ["su", "agency", "retailer"],
      "description": "Organizational scope"
    },
    "userType": {
      "type": "string",
      "enum": ["owner", "admin", "lead", "member", "collaborator"],
      "description": "Permission role"
    },
    "name": {
      "type": "string",
      "description": "Human-readable identifier (username, email)"
    },
    "products": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["footprints", "signage", "qr", "reports", "connect"]
      },
      "description": "Product codes where user has subscription access"
    },
    "agencyId": {
      "type": "string",
      "description": "Agency ID (required if userLevel is agency or retailer)"
    },
    "retailerId": {
      "type": "string",
      "description": "Retailer ID (required if userLevel is retailer)"
    },
    "actingAs": {
      "type": "object",
      "description": "Act AS delegation (only present if user is delegating)",
      "properties": {
        "level": {
          "type": "string",
          "enum": ["agency", "retailer"],
          "description": "Target level for delegation"
        },
        "retailerId": {
          "type": "string",
          "description": "Target retailer ID when acting as retailer"
        },
        "agencyId": {
          "type": "string",
          "description": "Target agency ID when acting as agency"
        }
      },
      "required": ["level"]
    }
  },
  "required": ["id", "userLevel", "userType", "name", "products"]
}
